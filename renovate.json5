{
  branchPrefix: 'renovate.',
  extends: [
    'config:best-practices',
    ':rebaseStalePrs',
  ],
  packageRules: [
    {
      matchUpdateTypes: [
        'major',
      ],
      groupName: null,
      matchPackageNames: [
        '*',
      ],
      prConcurrentLimit: 1,
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'digest',
      ],
      groupName: 'bump-dependencies',
      schedule: [
        '* 12 * * 3',
      ],
    },
    {
      matchDepTypes: [
        'action',
      ],
      groupName: 'github-actions',
      commitMessagePrefix: '[skip-release] ',
    },
  ],
  labels: [
    'dependencies',
  ],
  osvVulnerabilityAlerts: true,
  dependencyDashboardOSVVulnerabilitySummary: 'unresolved',
  vulnerabilityAlerts: {
    enabled: true
  },
}
