{
  "name": "mirador-integration-drupal",
  "version": "1.0.0",
  "description": "Allow Drupal to display the Mirador image viewer",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
